{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/chidakiyo/json-gantt-viewer/master/docs/schema.json",
  "title": "json-gantt-viewer データスキーマ",
  "description": "ガントチャートビューアーが読み込む JSON の構造。人間可読な解説は docs/DATA-SCHEMA.md を参照。日付はすべて YYYY-MM-DD。",
  "type": "object",
  "required": [
    "projects"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "$comment": {
      "type": "string"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "calendar": {
      "$ref": "#/$defs/calendar"
    },
    "assignees": {
      "type": "object",
      "description": "担当コード → 担当者。タスクの who がこのキーを参照する。",
      "additionalProperties": {
        "$ref": "#/$defs/assignee"
      }
    },
    "projects": {
      "type": "array",
      "description": "プロジェクトの一覧。上から縦に並ぶ。",
      "items": {
        "$ref": "#/$defs/project"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "YYYY-MM-DD 形式の日付。"
    },
    "localized": {
      "type": "object",
      "description": "日英の表示ラベル。片方だけ運用する場合は同じ値でも可。",
      "properties": {
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "meta": {
      "type": "object",
      "description": "左上のタイトル／サブタイトル（日英）。省略時は既定の文言。",
      "properties": {
        "ja": {
          "$ref": "#/$defs/metaLabel"
        },
        "en": {
          "$ref": "#/$defs/metaLabel"
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "metaLabel": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "calendar": {
      "type": "object",
      "description": "稼働日カレンダー。省略時は月〜金稼働・祝日なし。",
      "properties": {
        "workweek": {
          "type": "array",
          "description": "稼働する曜日（0=日 … 6=土）。既定 [1,2,3,4,5]。",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          }
        },
        "holidays": {
          "type": "array",
          "description": "休業日。オブジェクトまたは日付文字列。",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/date"
              },
              {
                "type": "object",
                "required": [
                  "date"
                ],
                "properties": {
                  "date": {
                    "$ref": "#/$defs/date"
                  },
                  "ja": {
                    "type": "string"
                  },
                  "en": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  }
                },
                "additionalProperties": false,
                "patternProperties": {
                  "^\\$": {}
                }
              }
            ]
          }
        },
        "extraWorkdays": {
          "type": "array",
          "description": "本来は休みだが稼働する日（休日出勤の土曜など）。",
          "items": {
            "$ref": "#/$defs/date"
          }
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "assignee": {
      "type": "object",
      "description": "担当者。color / abbr は省略時に自動生成。",
      "properties": {
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "color": {
          "type": "string",
          "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$",
          "description": "アバターの色（hex）。省略可。"
        },
        "abbr": {
          "type": "string",
          "description": "アバターに出す文字。省略可。"
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "project": {
      "type": "object",
      "required": [
        "id",
        "phases"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "accent": {
          "type": "boolean",
          "description": "true で主役プロジェクトとして淡いアクセント背景。既定 false。"
        },
        "milestones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/milestone"
          }
        },
        "phases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/phase"
          }
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "milestone": {
      "type": "object",
      "required": [
        "date"
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/date"
        },
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "rose": {
          "type": "boolean",
          "description": "true で重要マイルストーンを赤系で強調。既定 false。"
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "phase": {
      "type": "object",
      "required": [
        "id",
        "tasks"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/task"
          }
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    },
    "task": {
      "type": "object",
      "required": [
        "id",
        "plan"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "who": {
          "type": "string",
          "description": "assignees のキー。省略可。"
        },
        "plan": {
          "type": "object",
          "description": "予定期間。",
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "$ref": "#/$defs/date"
            },
            "end": {
              "$ref": "#/$defs/date"
            }
          },
          "additionalProperties": false,
          "patternProperties": {
            "^\\$": {}
          }
        },
        "actual": {
          "type": "object",
          "description": "実績期間。未着手は start=null、進行中は end=null。",
          "properties": {
            "start": {
              "oneOf": [
                {
                  "$ref": "#/$defs/date"
                },
                {
                  "type": "null"
                }
              ]
            },
            "end": {
              "oneOf": [
                {
                  "$ref": "#/$defs/date"
                },
                {
                  "type": "null"
                }
              ]
            },
            "$note": {
              "type": "string"
            }
          },
          "additionalProperties": false,
          "patternProperties": {
            "^\\$": {}
          }
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "進捗率 0〜1。既定 0。"
        },
        "personDays": {
          "type": "number",
          "minimum": 0,
          "description": "工数（人日）。既定 0。"
        },
        "critical": {
          "type": "boolean",
          "description": "クリティカルパス上なら true。既定 false。"
        },
        "deps": {
          "type": "array",
          "description": "先行タスクの id 配列。",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "patternProperties": {
        "^\\$": {}
      }
    }
  },
  "patternProperties": {
    "^\\$": {}
  }
}
