{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "json-gantt-viewer data (v2)",
  "description": "ガントチャートビューアーのデータ契約 v2。階層は children による再帰構造（任意の深さ）。v1（phases/tasks）もビューアーは読めるが、生成時は本スキーマ（v2）に従うこと。",
  "type": "object",
  "required": [
    "projects"
  ],
  "additionalProperties": false,
  "patternProperties": {
    "^\\$": {
      "type": "string"
    }
  },
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ja": {
          "$ref": "#/$defs/metaLang"
        },
        "en": {
          "$ref": "#/$defs/metaLang"
        }
      },
      "patternProperties": {
        "^\\$": {
          "type": "string"
        }
      }
    },
    "calendar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workweek": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6
          },
          "description": "稼働する曜日 (0=日 … 6=土)。既定 [1,2,3,4,5]"
        },
        "holidays": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
              },
              {
                "type": "object",
                "required": [
                  "date"
                ],
                "additionalProperties": false,
                "properties": {
                  "date": {
                    "$ref": "#/$defs/date"
                  },
                  "ja": {
                    "type": "string"
                  },
                  "en": {
                    "type": "string"
                  }
                },
                "patternProperties": {
                  "^\\$": {
                    "type": "string"
                  }
                }
              }
            ]
          }
        },
        "extraWorkdays": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/date"
          },
          "description": "本来休みだが稼働する日"
        }
      },
      "patternProperties": {
        "^\\$": {
          "type": "string"
        }
      }
    },
    "assignees": {
      "type": "object",
      "description": "担当者マスタ。キー=担当コード（タスクの who が参照）",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ja": {
            "type": "string"
          },
          "en": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{3,8}$"
          },
          "abbr": {
            "type": "string",
            "maxLength": 4
          }
        },
        "patternProperties": {
          "^\\$": {
            "type": "string"
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/project"
      }
    }
  },
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "dateOrNull": {
      "oneOf": [
        {
          "$ref": "#/$defs/date"
        },
        {
          "type": "null"
        }
      ]
    },
    "metaLang": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        }
      },
      "patternProperties": {
        "^\\$": {
          "type": "string"
        }
      }
    },
    "milestone": {
      "type": "object",
      "required": [
        "date"
      ],
      "additionalProperties": false,
      "properties": {
        "date": {
          "$ref": "#/$defs/date"
        },
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "rose": {
          "type": "boolean",
          "description": "true で重要マイルストーンとして赤系強調"
        }
      },
      "patternProperties": {
        "^\\$": {
          "type": "string"
        }
      }
    },
    "project": {
      "type": "object",
      "required": [
        "id",
        "children"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "accent": {
          "type": "boolean"
        },
        "milestones": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/milestone"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        }
      },
      "patternProperties": {
        "^\\$": {
          "type": "string"
        }
      }
    },
    "node": {
      "type": "object",
      "description": "children が非空ならグループ（バー・工数・進捗は配下から自動集計。plan 等は持たせない）。children が空/省略ならタスク（plan 必須）。",
      "required": [
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "全体で一意。deps から参照される"
        },
        "ja": {
          "type": "string"
        },
        "en": {
          "type": "string"
        },
        "who": {
          "type": "string",
          "description": "assignees のキー。未定義の文字列も可（色は自動割当）"
        },
        "plan": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start": {
              "$ref": "#/$defs/dateOrNull"
            },
            "end": {
              "$ref": "#/$defs/dateOrNull"
            }
          },
          "patternProperties": {
            "^\\$": {
              "type": "string"
            }
          }
        },
        "actual": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "start": {
              "$ref": "#/$defs/dateOrNull",
              "description": "null=未着手"
            },
            "end": {
              "$ref": "#/$defs/dateOrNull",
              "description": "null=進行中。日付を入れる（完了扱いにする）場合は progress を必ず 1 にすること"
            }
          },
          "patternProperties": {
            "^\\$": {
              "type": "string"
            }
          }
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "0〜1 の小数。※ 1 を超える値はビューアー側で %表記とみなし /100 に自動補正されるが、生成時は必ず 0〜1 で出力すること。actual.end に日付を入れた完了タスクでは必ず 1 にする（矛盾させない）"
        },
        "personDays": {
          "type": "number",
          "minimum": 0
        },
        "critical": {
          "type": "boolean",
          "description": "クリティカルパス上のタスクなら true。true のタスク同士は deps で連結した一続きの鎖になるように付けること"
        },
        "deps": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "先行タスクの id 配列。実在するタスク id のみ。依存は FS（先行の終了→自分の開始）のみで、ラグや SS/FF は表現できない"
        },
        "note": {
          "type": "string"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/node"
          }
        }
      },
      "if": {
        "anyOf": [
          {
            "not": {
              "required": [
                "children"
              ]
            }
          },
          {
            "properties": {
              "children": {
                "maxItems": 0
              }
            }
          }
        ]
      },
      "then": {
        "required": [
          "id",
          "plan"
        ]
      },
      "patternProperties": {
        "^\\$": {
          "type": "string"
        }
      }
    }
  }
}
